{
  "name": "privara-tests",
  "version": "1.0.0",
  "description": "Run unit tests on Privara contracts.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "typecheck": "tsc --noEmit -p tsconfig.scripts.json",
    "deposit": "tsx scripts/deposit.ts",
    "create-intent": "tsx scripts/create-intent.ts",
    "settle": "tsx scripts/settle.ts",
    "status": "tsx scripts/status.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.9.0",
    "@stacks/transactions": "^7.2.0",
    "chokidar-cli": "^3.0.0",
    "vitest": "^4.0.7",
    "vitest-environment-clarinet": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
